{
  "name": "@newhighsco/next",
  "description": "New High Score Next.js plugins",
  "author": "New High Score",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "example",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/newhighsco/next.git"
  },
  "homepage": "https://github.com/newhighsco/next#readme",
  "bugs": {
    "url": "https://github.com/newhighsco/next/issues"
  },
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "prepare": "husky",
    "start": "yarn workspace example start",
    "build": "yarn workspace example build",
    "pretest": "yarn lint",
    "test": "jest --runInBand",
    "test:list": "jest --listTests",
    "lint": "concurrently 'yarn:lint:*'",
    "lint:js": "eslint --cache .",
    "format": "concurrently 'yarn:format:*'",
    "format:js": "yarn lint:js --fix"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-env": "8.0.2",
    "@commitlint/cli": "21.1.0",
    "@newhighsco/commitlint-config": "1.3.2",
    "@newhighsco/editor-config": "1.2.0",
    "@newhighsco/eslint-config": "7.1.15",
    "@newhighsco/prettier-config": "2.3.10",
    "@newhighsco/release-config": "1.5.1",
    "@newhighsco/yarn-plugin-preset": "1.1.4",
    "@qiwi/multi-semantic-release": "7.1.2",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-junit": "17.0.0",
    "prettier": "3.9.4",
    "semantic-release": "25.0.5"
  },
  "commitlint": {
    "extends": [
      "@newhighsco"
    ]
  },
  "multi-release": {
    "sequentialInit": true
  },
  "prettier": "@newhighsco/prettier-config",
  "release": {
    "extends": "@newhighsco/release-config"
  }
}
